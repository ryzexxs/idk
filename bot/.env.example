# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Application Client ID (from Developer Portal)
DISCORD_CLIENT_ID=your_client_id_here

# Discord Application Client Secret (from Developer Portal)
DISCORD_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI
# For Vercel: https://your-project.vercel.app/callback
# For local testing: http://localhost:3000/callback
OAUTH_REDIRECT_URI=https://your-project.vercel.app/callback

# JWT Secret for stateless verification (optional - auto-generated if not set)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Log Channel ID (optional - Discord channel ID where verification logs are sent)
# To get this: Right-click a channel > Copy Channel ID (enable Developer Mode in Discord)
LOG_CHANNEL_ID=your_log_channel_id_here

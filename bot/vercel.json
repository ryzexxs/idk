{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/callback",
      "dest": "/api/callback.js"
    },
    {
      "src": "/api/osint",
      "dest": "/api/osint.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
